{
  // ====== ISO settings ====================================================
  "iso_url": "https://download.freebsd.org/ftp/releases/ISO-IMAGES/13.5/FreeBSD-13.5-RELEASE-amd64-disc1.iso",
  "iso_checksum": "sha512:1842b1113dd541705fc606d103a071ef2586f7ca5a967253dffa50d2bf2f9b68faf8fa09988bc2223838f4301f587611c5ade31b3567b599caf52f942b5a03c3",
  "ssh_username": "{{user `user_name`}}",
  "ssh_password": "{{user `user_password`}}",
  "ssh_pty": true,
  "ssh_timeout": "60m",
  "ssh_handshake_attempts": "1024",
  // No shutdown_command needed!

  // ====== Boot into installer =============================================
  // !!! IMPORTANT: The "vboxmanage" here will REPLACE all "vboxmanage"
  //                settings from vmsetup/virtualbox*.json!
  "vboxmanage": [
    // FIXME! virtio NIC type does not work for FreeBSD guest in current VirtualBox!
    [ "modifyvm", "{{.Name}}", "--nictype1", "82545EM" ],
    // FIXME! FreeBSD guest in current VirtualBox needs VBoxSVGA!
    [ "modifyvm", "{{.Name}}", "--graphicscontroller", "vboxsvga" ],
    [ "modifyvm", "{{.Name}}", "--ostype", "FreeBSD_64" ]
  ],
  "boot_wait": "45s",
  "boot_command": [
    "s<enter><wait>",
    "cd /tmp && dhclient $(ifconfig -l | cut -d' ' -f1) && ",
    "fetch http://{{ .HTTPIP }}:{{ .HTTPPort }}/installer && ",
    "fetch http://{{ .HTTPIP }}:{{ .HTTPPort }}/installerconfig && ",
    "fetch http://{{ .HTTPIP }}:{{ .HTTPPort }}/zfsboot && ",
    "ping -c3 -i0.3 www.heise.de && ",
    "chmod +x installer zfsboot && ",
    "./installer script /tmp/installerconfig<enter>"
   ]
}
