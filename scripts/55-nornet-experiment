# Bash options:
set -euxo pipefail


UNAME="$(uname)"


# ====== Experiment user configuration ======================================
if [ "${UNAME}" == "Linux" ] ; then

   # Create experiment user:
   adduser experiment --disabled-password --gecos "NorNet Experiment User"
   usermod -a -G adm,sudo experiment

elif [ "${UNAME}" == "FreeBSD" ] ; then

   # TBD!
   true

fi


# ====== Package installation ===============================================

# ------ Ubuntu/Debian ------------------------------------------------------
if [ "${ID}" == "ubuntu" ] || [ "${ID}" == "debian" ] ; then

   packages="
      nornet-node
   "

   # shellcheck disable=SC2086
   env DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends ${packages}


# ------ Fedora -------------------------------------------------------------
elif [ "${ID}" == "fedora" ] ; then

   packages="
      nornet-node
   "

   # shellcheck disable=SC2086
   dnf install --setopt=install_weak_deps=False -y ${packages}


# ------ FreeBSD ------------------------------------------------------------
elif [ "${ID}" == "freebsd" ] ; then

   # TBD!
   true

fi
